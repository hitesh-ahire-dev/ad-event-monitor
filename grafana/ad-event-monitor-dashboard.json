{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "schemaVersion": 39,
  "tags": ["ad-event-monitor", "kafka", "enrichment"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "title": "AD Event Monitor",
  "uid": "ad-event-monitor",
  "version": 2,
  "panels": [
    {
      "type": "row",
      "title": "Kafka",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 100
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Consumer lag (records-lag-max)",
      "description": "Maximum lag across partitions for the ad-event-monitor consumer group. Rising = consumer can't keep up.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "max by (client_id) (kafka_consumer_fetch_manager_records_lag_max)",
          "legendFormat": "{{client_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Messages consumed / sec",
      "description": "Kafka client throughput.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_consumer_fetch_manager_records_consumed_total[1m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Event Processing",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "id": 101
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total events processed",
      "description": "Cumulative count of events the consumer has handled (all results).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        { "expr": "sum(ad_events_processed_total)", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Failure rate (success vs failure)",
      "description": "Per-second rate of processed events, split by result.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "skipped" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (result) (rate(ad_events_processed_total[1m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Enrichment",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "id": 102
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Enrichment success vs failure (static & dynamic)",
      "description": "Rate of enrichment outcomes per type.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (type, result) (rate(ad_enrichment_total[1m]))",
          "legendFormat": "{{type}} - {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Enrichment latency p95 (static vs dynamic)",
      "description": "Per-type 95th-percentile latency.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, type) (rate(ad_enrichment_latency_seconds_bucket[5m])))",
          "legendFormat": "{{type}} p95",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Errors & System",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false,
      "id": 103
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Exceptions per second (by stage)",
      "description": "Caught exceptions in the consumer, tagged by the stage that produced them.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (stage) (rate(ad_events_exceptions_total[1m]))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "JVM heap used vs committed",
      "description": "Used / committed heap. Sustained close-to-committed = memory pressure.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "used", "refId": "A" },
        { "expr": "sum(jvm_memory_committed_bytes{area=\"heap\"})", "legendFormat": "committed", "refId": "B" }
      ]
    }
  ],
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
